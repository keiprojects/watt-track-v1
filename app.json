{
  "expo": {
    "name": "Watt Track",
    "slug": "watt-track",
    "scheme": "watttrack",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "image": "./assets/branding/logo-full.png",
          "resizeMode": "contain",
          "backgroundColor": "#04111d",
          "imageWidth": 220
        }
      ],
      "expo-router",
      "expo-document-picker",
      "expo-file-system",
      "expo-notifications",
      "expo-sharing",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "94b69d50-1778-4481-912f-c5f068ebe648"
      }
    },
    "owner": "keiprojects",
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "android": {
      "package": "com.keiprojects.watttrack",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#04111d"
      }
    }
  }
}
