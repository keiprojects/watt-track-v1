{
  "expo": {
    "name": "Watt Track",
    "slug": "watt-track",
    "scheme": "watttrack",
    "version": "1.0.0",
    "icon": "./assets/icon.png",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "plugins": [
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#f4f8fb",
          "image": "./assets/splash/splash-logo-light.png",
          "imageWidth": 180,
          "resizeMode": "contain",
          "dark": {
            "backgroundColor": "#04111d",
            "image": "./assets/splash/splash-logo-dark.png"
          }
        }
      ],
      "expo-router",
      "expo-document-picker",
      "expo-file-system",
      "expo-notifications",
      "expo-sharing",
      "expo-status-bar"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "94b69d50-1778-4481-912f-c5f068ebe648"
      }
    },
    "owner": "keiprojects",
    "description": "Local-first solar, grid, savings, and ROI tracking for household energy systems.",
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png"
    },
    "ios": {
      "bundleIdentifier": "com.keiprojects.watttrack",
      "supportsTablet": false
    },
    "android": {
      "package": "com.keiprojects.watttrack",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#04111d"
      }
    },
    "androidStatusBar": {
      "barStyle": "dark-content",
      "backgroundColor": "#f4f8fb",
      "translucent": false
    }
  }
}
